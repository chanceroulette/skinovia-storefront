# Shopify Storefront API — set these in Vercel
SHOPIFY_STORE_DOMAIN=vbe6qe-kq.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=your_storefront_api_access_token

# Analytics — set these in Vercel (Production + Preview)
# Both are optional: if a variable is missing, that tag is simply not loaded.
# GA4 Measurement ID, format G-XXXXXXXXXX (Google Analytics > Admin > Data streams)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Meta Pixel ID, numeric (Meta Events Manager > Data sources)
NEXT_PUBLIC_FB_PIXEL_ID=
